<div class="sw">
  <div class="si">
    <div class="sb">
      <span style="color:rgba(90,123,255,.45)">✦</span>
      <input id="search-input" type="text" placeholder="ค้นหาไฟล์หรือโฟลเดอร์…" oninput="onSearch(this.value)">
