<div id="pv-modal" onclick="if(event.target===this)closePV()">
  <div class="pv-box">
    <div class="pv-hdr">
      <div class="pv-ico" id="pv-ico">📄</div>
      <div class="pv-title" id="pv-title">—</div>
      <div class="pv-actions">
        <a class="pv-dl" id="pv-dl" href="#" download>⬇ ดาวน์โหลด</a>
        <button class="pv-close" onclick="closePV()">✕</button>
      </div>
