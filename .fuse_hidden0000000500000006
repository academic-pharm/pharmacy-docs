</div>

<footer>CPE 2567 · DOCUMENT SYSTEM · คณะเภสัชศาสตร์</footer>

<script>
let TREE_DATA=[];
let navStack=[],LC='th';
function setLang(l){
  LC=l;
  document.querySelectorAll('.lb').forEach(b=>b.classList.toggle('active',b.dataset.lang===l));
  document.querySelectorAll('[data-th]').forEach(el=>{if(!el.children.length)el.textContent=el.getAttribute('data-'+l)||el.getAttribute('data-th');});
  document.getElementById('search-input').placeholder=l==='th'?'ค้นหาไฟล์หรือโฟลเดอร์…':'Search files or folders…';
  renderCurrent();
}
const FI_ICO={'.pdf':'📄','.docx':'📝','.doc':'📝','.xlsx':'📊','.xls':'📊','.pptx':'📈','.ppt':'📈','.jpg':'🖼️','.jpeg':'🖼️','.png':'🖼️','.zip':'📦','.rar':'📦','.txt':'📃'};
const FI_BDG={'.pdf':['PDF','p'],'.docx':['DOCX','d'],'.doc':['DOC','d'],'.xlsx':['XLSX','x'],'.xls':['XLS','x'],'.jpg':['IMG','i'],'.jpeg':['IMG','i'],'.png':['PNG','i'],'.zip':['ZIP','z']};
const CLS={p:'bp',d:'bd',x:'bx',i:'bi',z:'bz'};
function gExt(n){const m=n.match(/\.([^.]+)$/);return m?m[0].toLowerCase():'';}
function gIco(e){return FI_ICO[e]||'📁';}
function gBdg(e){const b=FI_BDG[e];if(!b)return '';return `<span class="fbdg ${CLS[b[1]]||''}">${b[0]}</span>`;}
function mkURL(p){return p.split('/').map(encodeURIComponent).join('/');}
function cntF(ns){let f=0;for(const n of ns){if(n.type==='file')f++;else f+=cntF(n.children||[]);}return f;}
const FSTYLE={"ปีงบประมาณ 2567":["🌙","219,39,119"],"ปีงบประมาณ 2568":["⭐","6,182,212"],"ปีงบประมาณ 2569":["✨","16,185,129"],"ต่ออายุ":["♾️","168,85,247"],"บทความวิชาการ":["🔭","6,182,212"],"2.บทความวิชาการ":["🔭","6,182,212"],"พิจารณาหน่วยกิต":["🔬","20,184,166"],"ภาระงาน ผู้ทรง":["👑","245,158,11"],"ภาระงาน - ผู้ทรงคุณวุฒิ":["👑","245,158,11"],"4.ภาระงาน - ผู้ทรงคุณวุฒิ":["👑","245,158,11"],"ประชุมวิชาการ":["🌐","99,102,241"],"1.ประชุมวิชาการ":["🌐","99,102,241"],"3.ต่ออายุ":["♾️","168,85,247"],"5.ระเบียบและเลขบัญชี":["💎","124,58,237"],"1.โครงการบริการวิชาการ":["🚀","219,39,119"],"2.ไม่ใช่โครงการบริการวิชาการ":["🌀","6,182,212"],"3.โครงการติวใบประกอบ":["🎓","16,185,129"]};
function getStyle(name){for(const [k,v] of Object.entries(FSTYLE)){if(name===k||name.startsWith(k))return v;}return ['🗃️','90,123,255'];}
function openFolder(node){navStack.push(node);document.getElementById('search-input').value='';renderCurrent();window.scrollTo({top:0,behavior:'smooth'});}
function goBack(){if(navStack.length>0){navStack.pop();renderCurrent();window.scrollTo({top:0,behavior:'smooth'});}}
function navTo(d){navStack=navStack.slice(0,d+1);renderCurrent();window.scrollTo({top:0,behavior:'smooth'});}
function renderNavBar(){
  const bar=document.getElementById('nav-bar'),depth=navStack.length;
  if(depth===0){bar.innerHTML='';return;}
  let h=`<button class="btn-back" onclick="goBack()">← ${LC==='th'?'ย้อนกลับ':'Back'}</button>`;
  h+=`<span class="nav-sep">|</span><div class="bc"><span class="bc-item" onclick="navTo(-1)">⌂</span>`;
  navStack.forEach((node,i)=>{h+=`<span class="bc-sep">›</span>`;if(i<depth-1)h+=`<span class="bc-item" onclick="navTo(${i})">${node.name}</span>`;else h+=`<span class="bc-item cur">${node.name}</span>`;});
  h+=`</div>`;bar.innerHTML=h;
}
function renderCurrent(){
  renderNavBar();
  const cur=navStack.length===0?TREE_DATA:navStack[navStack.length-1].children||[];
  const folders=cur.filter(n=>n.type==='folder'),files=cur.filter(n=>n.type==='file');
  const con=document.getElementById('main-con');con.innerHTML='';
  if(folders.length>0){
    const useList=navStack.length>=2;
    const grid=document.createElement('div');grid.className=useList?'flist':'fgrid';
    for(const f of folders){
      const [ico,rgb]=getStyle(f.name);
      const fc=cntF(f.children||[]),fd=(f.children||[]).filter(c=>c.type==='folder').length;
      const isClosed=f.name.includes('(ปิดโครงการ)')||f.name.includes('(ปิด คก.');
      const card=document.createElement('div');
      card.style.setProperty('--fc-rgb',rgb);
      if(useList){
        card.className='fl'+(isClosed?' fc-closed':'');
        card.innerHTML=`
          <div class="fl-ico" style="background:rgba(${rgb},.1);border:1px solid rgba(${rgb},.22)">${ico}</div>
          <div class="fl-body">
            <div class="fl-name">${f.name}</div>
            <div class="fl-sub">
              ${fd>0?`<span>📁 ${fd}</span>`:''}
              <span>📄 ${fc}</span>
              ${isClosed?`<span class="fl-tag">✓ ${LC==='th'?'ปิดแล้ว':'Closed'}</span>`:''}
            </div>
          </div>
          <span class="fl-arr">→</span>`;
      } else {
        card.className='fc'+(isClosed?' fc-closed':'');
        card.innerHTML=`
          <div class="fc-top">
            <div class="fc-ico" style="background:rgba(${rgb},.1);border:1px solid rgba(${rgb},.24)">${ico}</div>
            <div>
              <div class="fc-name">${f.name}</div>
              ${isClosed?`<span class="fc-tag" style="background:rgba(5,150,105,.08);color:#059669;border:1px solid rgba(5,150,105,.18);margin-top:5px">✓ ${LC==='th'?'ปิดแล้ว':'Closed'}</span>`:''}
            </div>
          </div>
          <div class="fc-bot">
            <span class="fc-cnt">${fd>0?`📁 ${fd}  `:''}📄 ${fc}</span>
            <span class="fc-arr">→</span>
          </div>`;
      }
      card.addEventListener('click',()=>openFolder(f));grid.appendChild(card);
    }
    con.appendChild(grid);
  }
  if(files.length>0){
    const sec=document.createElement('div');sec.className='file-section';
    sec.innerHTML=`<div class="file-section-hdr">✦ ${LC==='th'?'ไฟล์ในโฟลเดอร์':'FILES'} <span style="font-weight:400;opacity:.5">(${files.length})</span></div>`;
    for(const f of files){
      const ext=gExt(f.name);
      const dlUrl=f.driveId?'https://drive.google.com/uc?export=download&id='+f.driveId:mkURL(f.path);
      const pvUrl=f.driveId?'https://drive.google.com/file/d/'+f.driveId+'/preview':dlUrl;
      const row=document.createElement('div');row.className='fi';
      row.innerHTML=`<span class="fi-ico">${gIco(ext)}</span><span class="fi-name">${f.name}</span><span class="fi-meta">${gBdg(ext)}<button class="pbtn" onclick="openPV('${pvUrl}','${f.name.replace(/'/g,"\'")}','${ext}',${!!f.driveId})">👁 ${LC==='th'?'ดูก่อน':'Preview'}</button><a class="bdl" href="${dlUrl}" download="${f.name.replace(/"/g,'&quot;')}">⬇ ${LC==='th'?'ดาวน์โหลด':'DL'}</a></span>`;
      sec.appendChild(row);
    }
    con.appendChild(sec);
  }
  if(folders.length===0&&files.length===0){con.innerHTML=`<div class="no-res"><div style="font-size:2.5rem;margin-bottom:10px;opacity:.25">📂</div><p style="font-family:'Prompt',sans-serif;font-size:.8rem;letter-spacing:.08em">${LC==='th'?'— ไม่มีไฟล์ —':'— EMPTY —'}</p></div>`;}
}
let stmr=null;
function onSearch(q){clearTimeout(stmr);stmr=setTimeout(()=>doSearch(q.trim().toLowerCase()),200);}
function flatMatch(nodes,q,pp){const res=[];for(const n of nodes){const path=[...pp,n.name];if(n.type==='file'&&n.name.toLowerCase().includes(q))res.push({n,path});else if(n.type==='folder')res.push(...flatMatch(n.children||[],q,path));}return res;}
function hl(t,q){if(!q)return t;const i=t.toLowerCase().indexOf(q);if(i<0)return t;return t.slice(0,i)+`<mark class="hl">${t.slice(i,i+q.length)}</mark>`+hl(t.slice(i+q.length),q);}
function doSearch(q){
  const con=document.getElementById('main-con');if(!q){renderCurrent();return;}con.innerHTML='';
  const matches=flatMatch(TREE_DATA,q,[]);
  if(!matches.length){con.innerHTML=`<div class="no-res"><div style="font-size:2rem;margin-bottom:10px;opacity:.2">🔍</div><p style="font-family:'Prompt',sans-serif;font-size:.8rem;letter-spacing:.08em">${LC==='th'?'— ไม่พบไฟล์ —':'— NO RESULTS —'}</p></div>`;return;}
  const sr=document.createElement('div');sr.className='sr-wrap';
  sr.innerHTML=`<div class="sr-hdr">✦ ${LC==='th'?`พบ ${matches.length} ไฟล์`:`${matches.length} FILES FOUND`}</div>`;
  for(const {n,path} of matches){
    const ext=gExt(n.name);
    const dlUrl=n.driveId?'https://drive.google.com/uc?export=download&id='+n.driveId:mkURL(n.path);
    const pvUrl=n.driveId?'https://drive.google.com/file/d/'+n.driveId+'/preview':dlUrl;
    const row=document.createElement('div');row.className='sr-item';
    row.innerHTML=`<span class="fi-ico">${gIco(ext)}</span><div style="flex:1;min-width:0"><div class="fi-name">${hl(n.name,q)}</div><div class="sr-path">${path.slice(0,-1).join(' › ')}</div></div><span class="fi-meta">${gBdg(ext)}<button class="pbtn" onclick="openPV('${pvUrl}','${n.name.replace(/'/g,"\'")}','${ext}',${!!n.driveId})">👁</button><a class="bdl" href="${dlUrl}" download="${n.name.replace(/"/g,'&quot;')}">⬇</a></span>`;
    sr.appendChild(row);
  }
  con.appendChild(sr);
}
window.addEventListener('DOMContentLoaded',()=>{
  const con=document.getElementById('main-con');
  con.innerHTML='<div style="text-align:center;padding:80px 0;color:rgba(74,77,87,.45);font-size:1.2rem">⏳ กำลังโหลดข้อมูล…</div>';
  fetch('https://script.google.com/macros/s/AKfycbxLT5vp4HUm-HkuYaBrS9FJsm-ldAjNwwE6sVCP53fg4c-i79HgFzA3fkmwj5SxtlJU/exec?type=cpe&_t='+Date.now())
    .then(r=>{if(!r.ok)throw new Error(r.status);return r.json();})
    .then(data=>{
      TREE_DATA=data.children||[];
      var fc=0,fd=0;
      (function cnt(n){n.forEach(x=>{if(x.type==='file')fc++;else{fd++;cnt(x.children||[]);}})})(TREE_DATA);
      var el=document.getElementById('file-count');if(el)el.textContent='✦ '+fc.toLocaleString()+' ไฟล์';
      var el2=document.getElementById('folder-count');if(el2)el2.textContent='◈ '+fd.toLocaleString()+' โฟลเดอร์';
      renderCurrent();
    })
    .catch(()=>{
      con.innerHTML='<div style="text-align:center;padding:80px 0;color:rgba(220,38,38,.7);font-size:1.1rem">❌ โหลดข้อมูลไม่สำเร็จ<br><small style="color:rgba(74,77,87,.5);font-size:.85rem">กรุณารีเฟรชหน้า</small></div>';
    });
});

// ═══ PREVIEW ═══
const IMG_EXT=new Set(['.jpg','.jpeg','.png','.gif','.webp','.svg','.bmp']);
const ICO_MAP={'.pdf':'📄','.docx':'📝','.doc':'📝','.xlsx':'📊','.xls':'📊','.pptx':'📈','.ppt':'📈','.jpg':'🖼️','.jpeg':'🖼️','.png':'🖼️','.gif':'🖼️','.zip':'📦','.rar':'📦','.txt':'📃'};
function openPV(url,name,ext,isDrive){
  document.getElementById('pv-title').textContent=name;
  document.getElementById('pv-ico').textContent=ICO_MAP[ext]||'📁';
  const dl=document.getElementById('pv-dl');dl.href=url;dl.download=name;
  const body=document.getElementById('pv-body');body.innerHTML='';
  if(isDrive||ext==='.pdf'){
    const ifr=document.createElement('iframe');ifr.src=url;body.appendChild(ifr);
  } else if(!isDrive&&IMG_EXT.has(ext)){
    const img=document.createElement('img');img.src=url;img.alt=name;body.appendChild(img);
  } else if(ext==='.txt'||ext==='.md'){
    body.innerHTML='<div style="padding:24px;width:100%;height:100%;overflow:auto"><pre id="pv-txt" style="color:#16181f;font-family:\'Kanit\',sans-serif;font-size:.85rem;line-height:1.7;white-space:pre-wrap;word-break:break-word">กำลังโหลด…</pre></div>';
    fetch(url).then(r=>r.text()).then(t=>{const p=document.getElementById('pv-txt');if(p)p.textContent=t;}).catch(()=>{const p=document.getElementById('pv-txt');if(p)p.textContent='ไม่สามารถโหลดได้';});
  } else {
    const extLabel=ext.replace('.','').toUpperCase();
    body.innerHTML=`<div class="pv-unsupported"><div class="pv-ext">${ICO_MAP[ext]||'📁'}</div><p>ไม่รองรับการแสดงตัวอย่างไฟล์ .${extLabel}<br><span style="font-size:.72rem;opacity:.5">กรุณาดาวน์โหลดเพื่อเปิดดู</span></p></div>`;
  }
  document.getElementById('pv-modal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closePV(){
  document.getElementById('pv-modal').classList.remove('open');
  document.body.style.overflow='';
  setTimeout(()=>{document.getElementById('pv-body').innerHTML='';},300);
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closePV();});

// ═══ COUNTER ═══
function animCounter(el,target){
  const dur=1400,start=performance.now();
  function upd(now){const p=Math.min((now-start)/dur,1),e=1-Math.pow(1-p,4);el.textContent=Math.round(e*target).toLocaleString();if(p<1)requestAnimationFrame(upd);else el.textContent=target.toLocaleString();}
  requestAnimationFrame(upd);
}
document.addEventListener('DOMContentLoaded',()=>{
  document.querySelectorAll('[data-count]').forEach(el=>animCounter(el,parseInt(el.dataset.count)));
});

// ═══ CARD EFFECTS (tilt + ripple + stagger) ═══
function initCardEffects(grid){
  const cards=[...grid.children];
  cards.forEach((c,i)=>{
    c.style.opacity='0';
    setTimeout(()=>{c.style.animation=`cardIn .4s cubic-bezier(.4,0,.2,1) forwards`;},i*55+20);
  });
  cards.forEach(card=>{
    card.style.setProperty('--fd',(3.5+Math.random()*2.5)+'s');
    card.style.setProperty('--fdelay',(Math.random()*2)+'s');
    let tiltOn=false;
    card.addEventListener('mousemove',e=>{
      const r=card.getBoundingClientRect();
      const x=(e.clientX-r.left)/r.width,y=(e.clientY-r.top)/r.height;
      card.style.setProperty('--mx',x);card.style.setProperty('--my',y);
      tiltOn=true;
      card.style.transform=`perspective(900px) rotateX(${(y-.5)*-9}deg) rotateY(${(x-.5)*9}deg) scale(1.025)`;
    });
    card.addEventListener('mouseleave',()=>{
      tiltOn=false;
      card.style.transition='transform .5s cubic-bezier(.4,0,.2,1),border-color .3s,box-shadow .3s,background .3s';
      card.style.transform='';
      setTimeout(()=>{if(!tiltOn)card.style.transition='';},550);
    });
    card.addEventListener('click',e=>{
      const r=card.getBoundingClientRect(),rpl=document.createElement('span');
      const sz=Math.max(r.width,r.height)*2.4;
      const rgb=getComputedStyle(card).getPropertyValue('--fc-rgb').trim()||'90,123,255';
      rpl.style.cssText=`position:absolute;pointer-events:none;border-radius:50%;width:${sz}px;height:${sz}px;left:${e.clientX-r.left-sz/2}px;top:${e.clientY-r.top-sz/2}px;background:rgba(${rgb},.1);transform:scale(0);animation:rpl .6s ease-out forwards;z-index:10`;
      card.appendChild(rpl);setTimeout(()=>rpl.remove(),650);
    });
  });
}
const __origRC=renderCurrent;
renderCurrent=function(){__origRC.apply(this,arguments);const g=document.querySelector('.fgrid,.flist');if(g)initCardEffects(g);};

// ═══ AURA REACTIVE BACKGROUND ═══
(function(){
  let tx=.5,ty=.5,cx=.5,cy=.5;
  const cursor=document.getElementById('au-cursor');
  document.addEventListener('mousemove',e=>{
    tx=e.clientX/window.innerWidth;ty=e.clientY/window.innerHeight;
    if(cursor){cursor.style.left=e.clientX+'px';cursor.style.top=e.clientY+'px';}
  });
  (function tick(){
    cx+=(tx-cx)*.055;cy+=(ty-cy)*.055;
    document.body.style.setProperty('--mx',cx.toFixed(4));
    document.body.style.setProperty('--my',cy.toFixed(4));
    document.body.style.setProperty('--hue',(cx*220).toFixed(1));
    document.body.style.background='oklch(94.5% 0.018 '+(170+cx*100).toFixed(0)+')';
    requestAnimationFrame(tick);
  })();
})();

// ═══ AUTH BADGE ═══
document.addEventListener('DOMContentLoaded',()=>{
  const u=getUser();if(u)renderUserBadge('auth-bar',u);
});
